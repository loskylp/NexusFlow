# Dockerfile.web — Multi-stage build for the NexusFlow React frontend.
# Stage 1: Build the React app with Vite. Stage 2: Serve with nginx.
# See: ADR-004, ADR-005, TASK-001

# --- Build stage ---
FROM node:20-alpine AS builder

WORKDIR /app

COPY web/package.json web/package-lock.json* ./
RUN npm ci

COPY web/ .

RUN npm run build

# --- Runtime stage ---
FROM nginx:alpine

# Copy the built assets
COPY --from=builder /app/dist /usr/share/nginx/html

# nginx config: SPA routing (all paths serve index.html)
# /api and /events paths are NOT served by nginx — Traefik routes those to the API server.
# See: ADR-005 (Traefik routing), TASK-001
COPY nginx.conf /etc/nginx/conf.d/default.conf

EXPOSE 80

CMD ["nginx", "-g", "daemon off;"]
