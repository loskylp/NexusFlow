# NexusFlow staging environment variables.
# Copy to deploy/staging/.env on the staging host and populate before deploying.
# This file documents every variable used by the staging compose stack.
# See: ADR-005, TASK-029

# === Image configuration ===

# Docker image tag to deploy. Set by the CD pipeline from the git tag (e.g. demo-v1.0).
# Defaults to "latest" if not set, which Watchtower will manage automatically.
IMAGE_TAG=latest

# === Database ===

# PostgreSQL connection string.
# The staging database is provisioned on the shared nxlabs.cc PostgreSQL instance:
#   ssh deploy@nxlabs.cc /opt/postgres/provision.sh nexusflow_staging
# The host is "postgres" because nxlabs.cc exposes PostgreSQL on the "postgres" Docker network.
DATABASE_URL=postgresql://nexusflow_staging:CHANGE_ME@postgres:5432/nexusflow_staging

# === Worker configuration ===

# Comma-separated list of capability tags for Worker instances.
WORKER_TAGS=demo,etl

# === API configuration ===

# Session TTL in hours.
SESSION_TTL_HOURS=24

# === Heartbeat configuration (ADR-002) ===

HEARTBEAT_INTERVAL_SECONDS=5
HEARTBEAT_TIMEOUT_SECONDS=15
PENDING_SCAN_INTERVAL_SECONDS=10

# === Log retention (ADR-008) ===

LOG_HOT_RETENTION_HOURS=72
LOG_COLD_RETENTION_HOURS=720
