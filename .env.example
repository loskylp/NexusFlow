# NexusFlow environment variable documentation.
# Copy to .env and populate before running docker compose.
# See: ADR-005, TASK-001

# === Required ===

# PostgreSQL connection string.
# Development: use the postgres container started by docker compose.
# Production: use the shared infrastructure instance on nxlabs.cc.
DATABASE_URL=postgresql://nexusflow:nexusflow_dev@postgres:5432/nexusflow

# Redis connection string.
# NexusFlow manages its own Redis container (ADR-005 — service-managed Redis).
REDIS_URL=redis://redis:6379

# Database password for the postgres dev container.
DB_PASSWORD=nexusflow_dev

# === Worker configuration ===

# Comma-separated list of capability tags for Worker instances.
# Workers consume from streams matching these tags (queue:{tag}, ADR-001).
WORKER_TAGS=demo,etl

# Worker ID. Set to a unique string per worker instance.
# If empty, a UUID is generated on startup.
WORKER_ID=

# === API configuration ===

# TCP port the API server listens on.
API_PORT=8080

# Deployment environment. Affects log verbosity and CORS policy.
# Values: development | staging | production
ENV=development

# === Session configuration (ADR-006) ===

# Session TTL in hours. Default: 24.
SESSION_TTL_HOURS=24

# === Heartbeat configuration (ADR-002) ===

# How often workers emit heartbeats, in seconds. Default: 5.
HEARTBEAT_INTERVAL_SECONDS=5

# How long without a heartbeat before a worker is declared down, in seconds. Default: 15.
HEARTBEAT_TIMEOUT_SECONDS=15

# How often the Monitor scans for pending tasks from downed workers, in seconds. Default: 10.
PENDING_SCAN_INTERVAL_SECONDS=10

# === Log retention (ADR-008) ===

# How long log lines remain in Redis Streams (hot storage), in hours. Default: 72.
LOG_HOT_RETENTION_HOURS=72

# How long log lines remain in PostgreSQL (cold storage), in hours. Default: 720 (30 days).
LOG_COLD_RETENTION_HOURS=720

# === Demo infrastructure (docker compose --profile demo) ===

MINIO_ROOT_USER=minioadmin
MINIO_ROOT_PASSWORD=minioadmin
